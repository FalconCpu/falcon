
factorial:
0    start
1    mov   a, $1
2    mov   #0, 1
3    ble_i a, #0, @3
4    jmp   @1
5    lab   @3
6    mov   #1, 1
7    mov   $8, #1
8    jmp   @0
9    jmp   @2
10   lab   @1
11   mov   #2, 1
12   sub_i #3, a, #2
13   mov   $1, #3
14   call  factorial
15   mov   #4, $8
16   mul_i #5, a, #4
17   mov   $8, #5
18   jmp   @0
19   jmp   @2
20   lab   @4
21   lab   @2
22   lab   @0
23   end