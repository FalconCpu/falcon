
main:
0    start
1    mov   a, $1
2    mov   #0, 0
3    mov   total, #0
4    mov   #1, 0
5    mov   index, #1
6    jmp   @2
7    lab   @1
8    add_i #2, total, index
9    mov   total, #2
10   mov   #3, 1
11   add_i #4, index, #3
12   mov   index, #4
13   lab   @2
14   blt_i index, a, @1
15   jmp   @3
16   lab   @3
17   mov   $8, total
18   jmp   @0
19   lab   @0
20   end