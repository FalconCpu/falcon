
fun test(x:Int)
    val a = 1 + x
    val b = "hello "+"world"

@-------------------
Symbol table [test:FUNC:(Int)->Void  ]
FUNCTION test
   DECL x
      SYMBOL Int
   Symbol table [x:VAR:Int  a:VAR:Int  b:VAR:String  ]
   DECL a Int
      BINOP + Int
         INTLIT 1 Int
         SYMBOL x Int
   DECL b String
      BINOP + String
         STRLIT "hello " String
         STRLIT "world" String